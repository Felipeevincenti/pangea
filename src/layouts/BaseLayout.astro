---
import '../styles/global.css';

interface Props {
  title?: string;
  scrollable?: boolean;
}

const { title = 'PANGEA — Estudio de Diseño', scrollable = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class:list={[{ 'is-scrollable': scrollable }]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
