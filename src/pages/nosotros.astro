---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="PANGEA — Nosotros">
  <a href="/" class="back-bubble" aria-label="Volver al inicio">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 12H5M12 19l-7-7 7-7"/>
    </svg>
  </a>
  <div class="phone-frame phone-frame--scroll">
    <main class="about-content">

      <h1 class="about-heading">Nosotros</h1>

      <p class="about-text">
        En PANGEA somos un estudio de diseño apasionado por crear marcas, experiencias digitales y contenido visual que conectan con las personas.
      </p>

      <p class="about-text">
        Trabajamos con marcas y emprendedores para transformar ideas en identidades memorables, combinando creatividad, estrategia y expertise técnico.
      </p>

      <div class="about-placeholder">
        <p class="about-placeholder-text">Pronto más información aquí</p>
      </div>

    </main>
  </div>
</BaseLayout>

<style>
  .back-bubble {
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 9999;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    text-decoration: none;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    transition: background 0.2s, box-shadow 0.2s;
  }

  .back-bubble:hover {
    background: #fff;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60px 28px max(28px, env(safe-area-inset-bottom));
    text-align: center;
  }

  .about-heading {
    font-size: 24px;
    font-weight: 500;
    margin-bottom: 20px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
  }

  .about-text {
    font-size: 14px;
    color: var(--muted);
    max-width: 320px;
    line-height: 1.7;
    margin-bottom: 16px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
  }

  .about-placeholder {
    margin-top: 24px;
    padding: 24px;
    border-radius: var(--radius);
    background: #f0f0f0;
    width: 100%;
    max-width: 320px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.5s forwards;
  }

  .about-placeholder-text {
    font-size: 13px;
    color: #999;
    font-style: italic;
  }

  @media (min-width: 800px) {
    .about-content {
      padding: 80px 40px max(40px, env(safe-area-inset-bottom));
    }

    .about-text {
      max-width: 500px;
      font-size: 16px;
    }
  }
</style>
