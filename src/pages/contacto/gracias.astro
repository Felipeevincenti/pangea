---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="PANGEA — Gracias">
  <div class="thanks-frame">
    <div class="thanks-card">
      <h1 class="thanks-heading">Gracias por tu mensaje</h1>
      <p class="thanks-subtext">Recibimos tu idea y en breve te enviaremos una propuesta.</p>
      <div class="thanks-dots">
        <span class="thanks-dot"></span>
        <span class="thanks-dot"></span>
        <span class="thanks-dot"></span>
      </div>
    </div>
    <a href="/" class="thanks-back">Volver al inicio</a>
  </div>
</BaseLayout>

<style>
  .thanks-frame {
    width: 100%;
    min-height: 100dvh;
    background: #e8e8e8;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .thanks-card {
    width: 100%;
    background: #fff;
    padding: 48px 28px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .thanks-heading {
    font-size: 24px;
    font-weight: 500;
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
  }

  .thanks-subtext {
    font-size: 14px;
    color: var(--muted);
    max-width: 280px;
    line-height: 1.5;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.25s forwards;
  }

  .thanks-dots {
    display: flex;
    justify-content: space-evenly;
    width: 100%;
    max-width: 180px;
    margin-top: 36px;
    opacity: 0;
    animation: fadeIn 0.5s ease 0.5s forwards;
  }

  .thanks-dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #e8e8e8;
    animation: dotPulse 1.5s ease-in-out infinite;
  }

  .thanks-dot:nth-child(2) {
    animation-delay: 0.3s;
  }

  .thanks-dot:nth-child(3) {
    animation-delay: 0.6s;
  }

  .thanks-back {
    display: block;
    width: calc(100% - 56px);
    max-width: 370px;
    padding: 18px 0;
    margin-top: 28px;
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    color: var(--fg);
    background: #fff;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    transition: box-shadow 0.2s ease, transform 0.15s ease;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.65s forwards;
  }

  .thanks-back:hover {
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.12);
  }

  .thanks-back:active {
    transform: scale(0.98);
  }

  .thanks-back:active {
    transform: scale(0.98);
  }

  @keyframes dotPulse {
    0%, 60%, 100% {
      transform: scale(1);
      opacity: 0.5;
    }
    30% {
      transform: scale(1.3);
      opacity: 1;
    }
  }
</style>
