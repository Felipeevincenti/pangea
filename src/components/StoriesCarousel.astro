---
interface Story {
  type: 'image' | 'video';
  src: string;
}

interface Props {
  stories: Story[];
  title: string;
  tags: string;
}

const { stories, title, tags } = Astro.props;
const total = stories.length;
---

<div class="stories" data-total={total}>
  <div class="stories__media">
    {stories.map((story, i) => (
      story.type === 'video'
        ? <video class="stories__video" data-index={i} src={story.src} muted playsinline preload="metadata"></video>
        : <img class="stories__img" data-index={i} src={story.src} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
    ))}
  </div>

  <div class="stories__progress">
    {stories.map((_, i) => (
      <div class="stories__segment" data-index={i}>
        <div class="stories__fill"></div>
      </div>
    ))}
  </div>

  <div class="stories__bottom">
    <div class="stories__info">
      <h2 class="stories__title">{title}</h2>
      <p class="stories__tags">{tags}</p>
    </div>
  </div>

  <button class="stories__nav stories__nav--prev" aria-label="Anterior"></button>
  <button class="stories__nav stories__nav--next" aria-label="Siguiente"></button>

  <a href="/clientes" class="stories__back" aria-label="Volver">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 12H5M12 19l-7-7 7-7"/>
    </svg>
  </a>

  <button class="stories__pause" aria-label="Pausar">
    <svg class="stories__pause-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <rect x="6" y="4" width="4" height="16" rx="1"/>
      <rect x="14" y="4" width="4" height="16" rx="1"/>
    </svg>
    <svg class="stories__play-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <path d="M8 5v14l11-7z"/>
    </svg>
  </button>
</div>

<script>
  class StoriesController {
    private el: HTMLElement;
    private index = 0;
    private total: number;
    private fills: HTMLElement[];
    private imgs: HTMLElement[];
    private videos: HTMLMediaElement[];
    private timer = 0;
    private running = false;
    private paused = false;

    constructor(el: HTMLElement) {
      this.el = el;
      this.total = Number(el.dataset.total);
      this.fills = [...el.querySelectorAll<HTMLElement>('.stories__fill')];
      this.imgs = [...el.querySelectorAll<HTMLElement>('.stories__img')];
      this.videos = [...el.querySelectorAll<HTMLMediaElement>('.stories__video')];

      el.querySelector<HTMLElement>('.stories__nav--prev')!.onclick = (e) => { e.stopPropagation(); this.prev(); };
      el.querySelector<HTMLElement>('.stories__nav--next')!.onclick = (e) => { e.stopPropagation(); this.next(); };

      const pauseBtn = el.querySelector<HTMLElement>('.stories__pause')!;
      pauseBtn.onclick = (e) => { e.stopImmediatePropagation(); this.togglePause(); };

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') this.prev();
        if (e.key === 'ArrowRight') this.next();
      });

      this.go(0);
    }

    private togglePause() {
      this.paused = !this.paused;
      this.el.querySelector('.stories__pause')!.classList.toggle('paused', this.paused);
      if (this.paused) {
        this.pauseStory();
      } else {
        this.resumeStory();
      }
    }

    private pauseStory() {
      this.running = false;
      clearTimeout(this.timer);
      const vid = this.videos[this.index];
      if (vid) { vid.onended = null; vid.pause(); }
      const fill = this.fills[this.index];
      if (fill) {
        const w = getComputedStyle(fill).width;
        fill.style.transition = 'none';
        fill.style.width = w;
      }
    }

    private resumeStory() {
      this.running = true;
      const story = this.imgs[this.index] ? 'image' : 'video';
      if (story === 'video') {
        const vid = this.videos[this.index];
        if (vid) {
          vid.play().catch(() => {});
          vid.onended = () => this.next();
        }
      } else {
        const fill = this.fills[this.index];
        if (fill) {
          const parent = fill.parentElement!;
          const parentW = parent.offsetWidth;
          const currentW = parseFloat(getComputedStyle(fill).width);
          const pct = parentW > 0 ? (currentW / parentW) * 100 : 0;
          const remaining = Math.max(0, (100 - pct) / 100 * 3000);
          this.timer = window.setTimeout(() => this.next(), remaining);
          void fill.offsetHeight;
          fill.style.transition = `width ${remaining}ms linear`;
          fill.style.width = '100%';
        }
      }
    }

    private go(i: number) {
      this.stop();
      this.paused = false;
      this.el.querySelector('.stories__pause')!.classList.remove('paused');
      this.index = i;

      this.imgs.forEach((img, idx) => img.classList.toggle('active', idx === i));
      this.videos.forEach((vid, idx) => {
        vid.classList.toggle('active', idx === i);
        if (idx === i) vid.play().catch(() => {});
        else { vid.pause(); vid.currentTime = 0; }
      });

      this.fills.forEach((fill, idx) => {
        fill.style.transition = 'none';
        fill.style.width = idx < i ? '100%' : '0';
      });

      void this.fills[i].offsetHeight;
      this.fills[i].style.transition = '';
      this.fills[i].style.width = '100%';

      this.schedule();
    }

    private schedule() {
      this.running = true;
      const story = this.imgs[this.index] ? 'image' : 'video';
      const duration = story === 'image' ? 3000 : 0;

      if (story === 'video') {
        const vid = this.videos[this.index];
        if (vid) vid.onended = () => this.next();
      }

      if (duration > 0) {
        this.timer = window.setTimeout(() => this.next(), duration);
      }
    }

    private stop() {
      this.running = false;
      clearTimeout(this.timer);
      const vid = this.videos[this.index];
      if (vid) { vid.onended = null; vid.pause(); }
    }

    prev() {
      if (this.index > 0) this.go(this.index - 1);
    }

    next() {
      if (this.index < this.total - 1) this.go(this.index + 1);
    }
  }

  document.querySelectorAll<HTMLElement>('.stories').forEach((el) => new StoriesController(el));
</script>

<style>
  .stories {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: #000;
    user-select: none;
  }

  .stories__media {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
  }

  .stories__img,
  .stories__video {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .stories__img.active,
  .stories__video.active {
    opacity: 1;
  }

  .stories__progress {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    gap: 4px;
    padding: 12px 8px;
    z-index: 2;
  }

  .stories__segment {
    flex: 1;
    height: 3px;
    background: rgba(255, 255, 255, 0.35);
    border-radius: 2px;
    overflow: hidden;
  }

  .stories__fill {
    width: 0;
    height: 100%;
    background: #fff;
    border-radius: 2px;
    transition: width 3s linear;
  }

  .stories__bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 48px 20px max(20px, env(safe-area-inset-bottom));
    background: linear-gradient(transparent, rgba(0,0,0,0.65));
    pointer-events: none;
  }

  .stories__info {
    pointer-events: auto;
  }

  .stories__title {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  .stories__tags {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 4px;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
  }

  .stories__nav {
    position: absolute;
    top: 20px;
    bottom: 0;
    width: 50%;
    z-index: 2;
    border: none;
    background: transparent;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .stories__nav--prev { left: 0; }
  .stories__nav--next { right: 0; }

  .stories__back {
    position: absolute;
    top: 25px;
    left: 25px;
    z-index: 3;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    text-decoration: none;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    transition: background 0.2s, box-shadow 0.2s;
  }

  .stories__back:hover {
    background: #fff;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  .stories__pause {
    position: absolute;
    top: 25px;
    right: 25px;
    z-index: 3;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    transition: background 0.2s, box-shadow 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .stories__pause:hover {
    background: #fff;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  .stories__pause.paused .stories__pause-icon {
    display: none;
  }

  .stories__play-icon {
    display: none;
  }

  .stories__pause.paused .stories__play-icon {
    display: block;
  }

  @media (min-width: 800px) {
    .stories__title {
      font-size: 28px;
    }

    .stories__tags {
      font-size: 18px;
    }

    .stories__bottom {
      padding: 64px 32px max(32px, env(safe-area-inset-bottom));
    }
  }
</style>
